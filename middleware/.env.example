# --- Listener ---
PORT=3002

# --- Shared secret between Edge Function and middleware ---
# Must match SAP_MIDDLEWARE_KEY configured in Lovable Cloud secrets.
MIDDLEWARE_SHARED_SECRET=replace-with-a-long-random-string

# --- SAP Business Partner API ---
SAP_BP_API_URL=http://10.200.1.2:8000/vendor/bp/create?sap-client=300
SAP_BP_USERNAME=22000208
SAP_BP_PASSWORD=Nani@1432

# --- Behavior ---
SAP_REQUEST_TIMEOUT_MS=30000

# Comma-separated list of allowed CORS origins. Use * to allow any.
CORS_ORIGINS=*

# Set to "1" to allow self-signed / untrusted SAP TLS certificates.
ALLOW_INSECURE_TLS=0
